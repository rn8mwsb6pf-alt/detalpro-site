{
  "name": "garage-warehouse",
  "version": "1.0.0",
  "description": "Склад — Дорожный комплекс Гараж",
  "main": "main.js",
  "author": "Дорожный комплекс Гараж",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "dist": "electron-builder --win",
    "create-icons": "node ../electron-app/create-icons.js"
  },
  "dependencies": {
    "electron-store": "^8.2.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "ru.garage.warehouse",
    "productName": "Гараж — Склад",
    "copyright": "Copyright © 2025 Дорожный комплекс Гараж",
    "files": ["main.js", "preload.js", "index.html", "assets/**/*"],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Гараж — Склад"
    }
  }
}
