# Скопируйте этот файл в .env.local и заполните значения

# ── PostgreSQL ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://detalpro:password@localhost:5432/detalpro

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── NextAuth (авторизация) ───────────────────────────────────────────────────
# Генерация: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET=замените-на-случайную-строку-минимум-32-символа
NEXTAUTH_URL=http://localhost:3000

# ── 1С:УТ HTTP-сервис ────────────────────────────────────────────────────────
ONE_C_URL=http://192.168.1.10/ut/hs/site
ONE_C_LOGIN=WebUser
ONE_C_PASSWORD=WebPassword

# ── QWEP ─────────────────────────────────────────────────────────────────────
QWEP_API_URL=https://api.qwep.ru/v1
QWEP_API_TOKEN=ваш-токен-qwep
QWEP_MARKUP_RATIO=1.35

# ── СДЭК ─────────────────────────────────────────────────────────────────────
CDEK_API_URL=https://api.cdek.ru/v2
CDEK_CLIENT_ID=ваш-client-id
CDEK_CLIENT_SECRET=ваш-secret
# Тестовые данные СДЭК (для разработки):
# CDEK_CLIENT_ID=EMscd6r9JnFiQ3bLoyjJY6eM
# CDEK_CLIENT_SECRET=PjLZkKBHEiLK3YsjtNrt3TGNG0ahs3kG

# ── Контакты ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_MANAGER_PHONE=+78001234567
NEXT_PUBLIC_SITE_NAME=ДЕТАЛЬПРО

# ── Кэш ──────────────────────────────────────────────────────────────────────
SEARCH_CACHE_TTL=300
